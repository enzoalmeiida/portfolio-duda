{
  "name": "portfolio-duda",
  "version": "1.0.0",
  "description": "Portfólio minimalista para Publicidade & Artes Visuais",
  "main": "index.html",
  "scripts": {
    "dev": "concurrently \"npm run tailwind\" \"npm run serve\"",
    "tailwind": "tailwindcss -i ./css/styles.css -o ./css/output.css --watch",
    "serve": "http-server . -p 8000 -o",
    "build": "tailwindcss -i ./css/styles.css -o ./css/output.css --minify",
    "preview": "npm run build && http-server ."
  },
  "keywords": [
    "portfolio",
    "publicidade",
    "artes visuais",
    "design",
    "ui/ux"
  ],
  "author": "Seu Nome",
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "http-server": "^14.1.1",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.6"
  },
  "dependencies": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/seu-usuario/portfolio-duda"
  }
}
